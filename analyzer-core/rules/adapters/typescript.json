{
  "language": "typescript",
  "scopeTracking": "brace",
  "patterns": [
    {
      "id": "class",
      "nodeType": "CLASS",
      "regex": "\\bclass\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s+extends\\s+([a-zA-Z_][a-zA-Z0-9_.]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_extends": 2
      },
      "beginsScope": true
    },
    {
      "id": "interface",
      "nodeType": "INTERFACE",
      "regex": "\\binterface\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s+extends\\s+([a-zA-Z_][a-zA-Z0-9_.]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_extends": 2
      },
      "beginsScope": true
    },
    {
      "id": "function",
      "nodeType": "FUNCTION",
      "regex": "\\b(?:async\\s+)?function\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(([^)]*)\\)(?:\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_<>|&]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_params": 2,
        "meta_returnType": 3
      },
      "beginsScope": true
    },
    {
      "id": "arrow_function",
      "nodeType": "FUNCTION",
      "regex": "(?:export\\s+)?(?:const|let|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(?:async\\s+)?(?:\\(([^)]*)\\)(?:\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_<>|&]*))?|([a-zA-Z_][a-zA-Z0-9_]*))\\s*=>\\s*\\{",
      "groups": {
        "name": 1,
        "meta_params": 2,
        "meta_returnType": 3
      },
      "beginsScope": true
    },
    {
      "id": "method",
      "nodeType": "METHOD",
      "regex": "\\b(?:public|private|protected|static|async|override)?\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(([^)]*)\\)(?:\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_<>|&]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_params": 2,
        "meta_returnType": 3
      },
      "beginsScope": true,
      "onlyInScope": ["CLASS"]
    },
    {
      "id": "controlflow",
      "nodeType": "CONTROL_FLOW",
      "regex": "\\b(if|for|while|switch|try|catch|finally)\\b\\s*[\\(\\{]",
      "groups": {
        "name": 1
      },
      "beginsScope": true
    },
    {
      "id": "import",
      "nodeType": "EXTERNAL_NODE",
      "regex": "\\bimport\\s+(?:.*from\\s+)?['\"]([^'\"]+)['\"]",
      "groups": {
        "name": 1
      },
      "edgeType": "IMPORTS",
      "sourceIsFile": true
    },
    {
      "id": "call",
      "nodeType": "CALL_SITE",
      "regex": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
      "groups": {
        "name": 1
      },
      "edgeType": "CALLS",
      "isGlobal": true
    }
  ],
  "ignoreWords": [
    "if", "for", "while", "switch", "catch", "return", "on", "await", "async",
    "function", "class", "interface", "const", "let", "var", "import", "export",
    "new", "typeof", "instanceof", "this", "super"
  ],
  "skipLinePatterns": ["^\\s*//", "^\\s*/\\*", "^\\s*\\*", "^\\s*$"]
}
