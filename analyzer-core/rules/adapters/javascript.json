{
  "language": "javascript",
  "scopeTracking": "brace",
  "patterns": [
    {
      "id": "class",
      "nodeType": "CLASS",
      "regex": "\\bclass\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s+extends\\s+([a-zA-Z_][a-zA-Z0-9_.]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_extends": 2
      },
      "beginsScope": true
    },
    {
      "id": "interface",
      "nodeType": "INTERFACE",
      "regex": "\\binterface\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s+extends\\s+([a-zA-Z_][a-zA-Z0-9_.,\\s]+))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_extends": 2
      },
      "beginsScope": true
    },
    {
      "id": "enum",
      "nodeType": "ENUM",
      "regex": "\\benum\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\{",
      "groups": {
        "name": 1
      },
      "beginsScope": true
    },
    {
      "id": "function",
      "nodeType": "FUNCTION",
      "regex": "\\b(?:async\\s+)?function\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(([^)]*)\\)(?:\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_<>|&]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_params": 2,
        "meta_returnType": 3
      },
      "beginsScope": true
    },
    {
      "id": "arrow_function",
      "nodeType": "FUNCTION",
      "regex": "(?:export\\s+)?(?:const|let|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(?:async\\s+)?(?:\\(([^)]*)\\)(?:\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_<>|&]*))?|([a-zA-Z_][a-zA-Z0-9_]*))\\s*=>\\s*\\{",
      "groups": {
        "name": 1,
        "meta_params": 2,
        "meta_returnType": 3
      },
      "beginsScope": true
    },
    {
      "id": "method",
      "nodeType": "FUNCTION",
      "regex": "\\b(?:public|private|protected|static|async|override)?\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(([^)]*)\\)(?:\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_<>|&]*))?\\s*\\{",
      "groups": {
        "name": 1,
        "meta_params": 2,
        "meta_returnType": 3
      },
      "beginsScope": true,
      "onlyInScope": ["CLASS"]
    },
    {
      "id": "import",
      "nodeType": "EXTERNAL_NODE",
      "regex": "\\bimport\\s+(?:.*from\\s+)?['\"]([^'\"]+)['\"]",
      "groups": {
        "name": 1
      },
      "edgeType": "IMPORTS",
      "sourceIsFile": true
    },
    {
      "id": "global_call",
      "nodeType": "CALL_HEURISTIC",
      "regex": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "groups": {
        "name": 1
      },
      "isGlobal": true
    }
  ],
  "ignoreWords": [
    "if", "for", "while", "switch", "catch", "return", "on", "await", "async",
    "function", "class", "const", "let", "var", "import", "export",
    "new", "typeof", "instanceof", "this", "super", "yield", "void", "delete",
    "true", "false", "null", "undefined", "NaN", "Infinity",

    "console", "log", "warn", "error", "info", "debug", "trace",
    "process", "exit", "env", "argv",
    "setTimeout", "setInterval", "clearTimeout", "clearInterval", "setImmediate",
    "require", "module", "exports", "__dirname", "__filename",

    "Array", "Object", "String", "Number", "Boolean", "Symbol", "BigInt",
    "Math", "Date", "RegExp", "JSON", "Map", "Set", "WeakMap", "WeakSet",
    "Promise", "resolve", "reject", "then", "catch", "finally",
    "Buffer", "global", "window", "document", "navigator", "location",

    "push", "pop", "shift", "unshift", "splice", "slice", "concat",
    "map", "filter", "reduce", "forEach", "find", "findIndex",
    "every", "some", "includes", "indexOf", "lastIndexOf", "join",
    "split", "replace", "replaceAll", "trim", "trimStart", "trimEnd",
    "startsWith", "endsWith", "padStart", "padEnd", "repeat",
    "toLowerCase", "toUpperCase", "substring", "slice", "charAt",
    "keys", "values", "entries", "assign", "freeze", "create", "defineProperty",
    "hasOwnProperty", "toString", "valueOf", "parse", "stringify",
    "abs", "ceil", "floor", "round", "max", "min", "pow", "sqrt", "random",
    "now", "from", "of", "isArray", "length",

    "Error", "TypeError", "RangeError", "SyntaxError", "ReferenceError",
    "EvalError", "URIError", "InternalError", "AssertionError",
    "message", "stack", "name", "code", "cause",

    "get", "set", "has", "delete", "clear", "size", "add", "done", "value",
    "next", "throw", "return", "send", "end", "write", "read", "close", "open",
    "call", "apply", "bind", "prototype", "constructor",
    
    "getElementById", "querySelector", "querySelectorAll", "addEventListener",
    "removeEventListener", "createElement", "appendChild", "removeChild",
    "replaceChild", "setAttribute", "getAttribute", "removeAttribute",
    "classList", "addClass", "removeClass", "toggleClass", "style", "css",
    "target", "source", "parent", "children", "data", "cy", "cytoscape",
    "elements", "nodes", "edges", "layout", "run", "show", "hide", "filter",
    "removeClass", "addClass", "getElementById", "string", "boolean",
    "object", "default", "readFileSync", "writeFileSync", "existsSync",
    "join", "dirname", "basename", "resolve"
  ],
  "skipLinePatterns": ["^\\s*//", "^\\s*/\\*", "^\\s*\\*", "^\\s*$"]
}
