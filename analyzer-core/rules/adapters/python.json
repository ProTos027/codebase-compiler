{
  "language": "python",
  "scopeTracking": "indent",
  "patterns": [
    {
      "id": "class",
      "nodeType": "CLASS",
      "regex": "^(\\s*)class\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?:\\((.*?)\\))?\\s*:",
      "groups": {
        "indent": 1,
        "name": 2,
        "meta_extends": 3
      },
      "beginsScope": true
    },
    {
      "id": "function",
      "nodeType": "FUNCTION",
      "regex": "^(\\s*)(?:async\\s+)?def\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\((.*?)\\)(?:\\s*->\\s*(.*?))?\\s*:",
      "groups": {
        "indent": 1,
        "name": 2,
        "meta_params": 3,
        "meta_returnType": 4
      },
      "beginsScope": true,
      "promoteInScope": {
        "CLASS": "FUNCTION"
      }
    },
    {
      "id": "from_import",
      "nodeType": "EXTERNAL_NODE",
      "regex": "^(\\s*)from\\s+([a-zA-Z0-9_.]+)\\s+import\\s+([a-zA-Z0-9_.,\\s*]+)",
      "groups": {
        "name": 2
      },
      "edgeType": "IMPORTS",
      "sourceIsFile": true
    },
    {
      "id": "import",
      "nodeType": "EXTERNAL_NODE",
      "regex": "^(\\s*)import\\s+([a-zA-Z0-9_.,\\s]+)",
      "groups": {
        "name": 2
      },
      "edgeType": "IMPORTS",
      "sourceIsFile": true,
      "nameIsList": true
    },
    {
      "id": "global_call",
      "nodeType": "CALL_HEURISTIC",
      "regex": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "groups": {
        "name": 1
      },
      "isGlobal": true
    }
  ],
  "ignoreWords": [
    "if", "for", "while", "return", "elif", "else", "pass", "break", "continue",
    "lambda", "yield", "with", "assert", "del", "raise", "except", "finally",
    "async", "await", "def", "class", "import", "from", "as", "in", "not",
    "and", "or", "is", "True", "False", "None",

    "print", "len", "range", "type", "isinstance", "issubclass", "hasattr",
    "getattr", "setattr", "delattr", "callable", "iter", "next", "open",
    "input", "repr", "str", "int", "float", "bool", "list", "dict", "set",
    "tuple", "bytes", "enumerate", "zip", "map", "filter", "sorted",
    "reversed", "any", "all", "min", "max", "sum", "abs", "round", "pow",
    "hash", "id", "hex", "oct", "bin", "chr", "ord", "format", "vars", "dir",
    "globals", "locals", "eval", "exec", "staticmethod", "classmethod",
    "property", "super", "object", "slice",

    "Exception", "BaseException", "ValueError", "TypeError", "KeyError",
    "IndexError", "AttributeError", "ImportError", "ModuleNotFoundError",
    "NameError", "OSError", "IOError", "FileNotFoundError", "PermissionError",
    "TimeoutError", "RuntimeError", "RecursionError", "MemoryError",
    "OverflowError", "ZeroDivisionError", "StopIteration", "NotImplementedError",
    "AssertionError", "SystemExit", "KeyboardInterrupt", "ArithmeticError",
    "SyntaxError", "IndentationError", "UnicodeError", "Warning", "UserWarning",

    "append", "extend", "insert", "remove", "pop", "clear", "sort", "reverse",
    "copy", "count", "update", "items", "keys", "values", "get", "setdefault",
    "split", "join", "strip", "replace", "find", "startswith", "endswith",
    "upper", "lower", "encode", "decode", "read", "write", "close",
    "os", "sys", "re", "json", "time", "logging", "math", "random"
  ],
  "skipLinePatterns": ["^\\s*#", "^\\s*$"]
}
